# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ---------- Supioc / 生产 nginx（重要）----------
# 默认构建会请求同源 /api-proxy/...（不再默认直连 api.supioc.com），与 Vite dev 一致；生产须在 nginx 增加对 /api-proxy/ 的反代（见下）。
# 若仍要浏览器直连官方域名且对方已开 CORS，构建前设 VITE_SUPIOC_DIRECT_API=1。
# 修改下列变量后须重新 npm run build。
#
# 方式 A（默认，推荐）：统一前缀 /api-proxy（可不设任何 VITE_SUPIOC_*，与代码默认一致）
#   nginx 示例：
#     location /api-proxy/ {
#       proxy_pass https://api.supioc.com/;
#       proxy_ssl_server_name on;
#       proxy_set_header Host api.supioc.com;
#     }
#
# 可选：显式再指定前缀（一般与默认相同）
# VITE_SUPIOC_API_BASE=/api-proxy
#
# 方式 B：同源路径（VITE_SUPIOC_SAME_ORIGIN_API=1）
# nginx 须为下列路径分别反代，且 proxy_pass 用「无 URI」形式，完整路径透传到上游：
#   proxy_pass https://api.supioc.com;
# 示例（与下方 supiocUrl 路径一致）：
#   location /api/     { proxy_pass https://api.supioc.com; proxy_ssl_server_name on; proxy_set_header Host api.supioc.com; }
#   location /v1/      { proxy_pass https://api.supioc.com; proxy_ssl_server_name on; proxy_set_header Host api.supioc.com; }
#   location /v1beta/  { proxy_pass https://api.supioc.com; proxy_ssl_server_name on; proxy_set_header Host api.supioc.com; }
# 勿写 proxy_pass https://api.supioc.com/; 以免剥掉路径前缀导致 404。
#
# VITE_SUPIOC_SAME_ORIGIN_API=1
#
# 浏览器直连官方 API（需对方 CORS 允许你的站点）
# VITE_SUPIOC_DIRECT_API=1
